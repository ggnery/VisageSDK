# =============================================================================
# Standalone evaluation environment variables
# =============================================================================
# Used by `python eval.py`. Loads a trained checkpoint and runs an
# evaluator against a chosen eval dataset.

# Backbone (must match the architecture used to train the checkpoint)
BACKBONE=inception_resnet_v1
BACKBONE_CONFIG=./configs/backbone/inception_resnet_v1.yaml

# Trained model checkpoint
CHECKPOINT_PATH=./checkpoints/facenet/InceptionResNetV1_TripletLoss_ImageFolderDataset_best.pth

# Eval dataset — registered names: lfw_pairs, identification
EVAL_DATASET=lfw_pairs
EVAL_DATASET_CONFIG=./configs/dataset/eval/lfw_eval.yaml

# Eval transformation — registered names: lfw_eval (or any train/val transform)
EVAL_TRANSFORMATION=lfw_eval
EVAL_TRANSFORMATION_CONFIG=./configs/transformation/eval/lfw_eval_transformation.yaml

# Evaluator — registered names: verification, identification
EVALUATOR=verification
EVALUATOR_CONFIG=./configs/evaluator/lfw_verification.yaml
