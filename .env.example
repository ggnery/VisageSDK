# =============================================================================
# Component selection (registry name) + config path
# =============================================================================

# Backbone — registered names: inception_resnet_v1, inception_resnet_v2, inception_v4, mobilenetv3, lvface_vit_b
BACKBONE=mobilenetv3
BACKBONE_CONFIG=./configs/backbone/mobilenetv3.yaml

# Train/val dataset — registered names: image_folder
TRAIN_VAL_DATASET=image_folder
TRAIN_VAL_DATASET_CONFIG=./configs/dataset/train_val/casia_webface.yaml

# Train/val transformation — registered names: vgg_face2_train, vgg_face2_val,
# casia_webface_train, casia_webface_val.
# (Eval-only transformations such as `lfw_eval` are used by eval.py / periodic_eval,
# not by the train/val DataLoaders here.)
TRAIN_TRANSFORMATION=casia_webface_train
VAL_TRANSFORMATION=casia_webface_val
TRAIN_VAL_TRANSFORMATION_CONFIG=./configs/transformation/train_val/casia_webface.yaml

# Loss — registered names: triplet, center, cross_entropy, margin_cosine
LOSS=margin_cosine
LOSS_CONFIG=./configs/loss/margin_cosine.yaml

# Trainer config (no registry — single class)
TRAINER_CONFIG=./configs/trainer/mobilenetv3_from_scratch.yaml

# =============================================================================
# Optional components — leave SAMPLER / EARLY_STOPPER unset to disable
# =============================================================================

# Sampler — registered names: facenet
# SAMPLER=facenet
# SAMPLER_CONFIG=./configs/batch_sampler/facenet.yaml

# Early stopper — registered names: adaptive
EARLY_STOPPER=adaptive
EARLY_STOPPER_CONFIG=./configs/early_stopper/adaptive.yaml
